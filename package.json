{
    "name": "genga-movie",
    "productName": "Genga Movie",
    "version": "1.0.0",
    "description": "Exclusive Genga Movie Desktop App",
    "author": "Genga Movie Team",
    "main": "electron/main.js",
    "type": "commonjs",
    "scripts": {
        "start": "electron .",
        "dev:frontend": "cd frontend && npm run dev",
        "dev:desktop": "electron .",
        "build:frontend": "cd frontend && npm run build",
        "build:exe": "electron-builder"
    },
    "build": {
        "appId": "com.genga.movie",
        "directories": {
            "output": "dist"
        },
        "win": {
            "icon": "frontend/public/icon.ico",
            "signingHashAlgorithms": [],
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "allowToChangeInstallationDirectory": false,
            "shortcutName": "Genga Movie",
            "uninstallDisplayName": "Genga Movie",
            "artifactName": "GengaMovieSetup.exe"
        },
        "extraResources": [
            {
                "from": "dist-backend",
                "to": "backend"
            }
        ],
        "files": [
            "dist-frontend/**/*",
            "electron/**/*",
            "node-bridge.js",
            "package.json"
        ]
    },
    "dependencies": {
        "@consumet/extensions": "^1.8.8",
        "@genga-movie/aniwatch": "^1.0.1",
        "axios": "^1.13.6",
        "cheerio": "^1.2.0",
        "express": "^5.2.1"
    },
    "devDependencies": {
        "electron": "^31.0.0",
        "electron-builder": "^24.13.3"
    }
}
